const path = sprites[type] || '';
const animClass = animated ? 'animate-bob' : '';
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 16 14"
  width={size}
  height={size * (14 / 16)}
  fill="currentColor"
  shape-rendering="crispEdges"
  aria-hidden="true"
  class={`inline-block ${animClass} ${className}`}
  set:html={path}
/>
