---
// Sprite pixel art inline SVG (sin imagenes externas, escalable, accesible).
// Cada sprite es una grilla 16x16 o 16x14 con paths simples.
// Uso: <PixelSprite type="coin" size={32} class="text-brand-primary" />

interface Props {
  type: 'coin' | 'controller' | 'heart' | 'sword' | 'shield' | 'mushroom' | 'star' | 'cartridge' | 'skull' | 'key' | 'cup';
  size?: number;
  class?: string;
  animated?: boolean;
}

const { type, size = 32, class: className = '', animated = false } = Astro.props;

const sprites: Record<Props['type'], string> = {
