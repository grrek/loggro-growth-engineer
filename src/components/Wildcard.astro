---
import { Sparkles, X } from 'lucide-react';

const ejemplosValidos = [
  'Un MCP server propio para Loggro',
  'Un agente extra (no pedido) que postprocesa tu entrega',
  'Una herramienta CLI que automatice algo del flujo',
  'Una opinión fuerte: "leyendo el caso, creo que Loggro debería matar X canal"',
  'Un experimento que no funcionó + postmortem honesta',
  'Una mejora concreta del enunciado de esta prueba',
];

const noQueremos = [
  'Más Parte B con más pulido',
  'Demos en Lovable o Bolt sin código detrás',
  'Texto inflado sin contenido',
];
---

<section id="wildcard" class="py-20 md:py-28 px-6 md:px-8">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-baseline gap-3 mb-3">
      <p class="font-pixel text-[10px] uppercase tracking-widest text-brand-primary">{'> '} PARTE D · OPCIONAL</p>
      <span class="text-xs font-mono text-fg-subtle">modificador +5%</span>
    </div>
    <h2 class="text-3xl md:text-5xl font-bold mb-4 tracking-tight">
      El Wildcard
      <span class="block text-2xl md:text-3xl font-bold text-brand-primary mt-2">Sorpréndenos.</span>
    </h2>
    <p class="text-lg text-fg-muted mb-12 max-w-2xl">
      Espacio en blanco. Cualquier artefacto adicional que demuestre algo que la prueba no captura. Opcional, suma hasta 5% sobre la nota total.
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="p-7 rounded-xl border border-green-500/30 bg-green-500/[0.04]">
        <h3 class="text-lg font-bold mb-5 flex items-center gap-2 text-green-600 dark:text-green-400">
          <Sparkles size={20} /> Ejemplos válidos
        </h3>
        <p class="text-xs text-fg-subtle mb-4 italic">
          No copiés, son ilustraciones para abrirte la cabeza:
        </p>
        <ul class="space-y-2.5 text-sm">
          {ejemplosValidos.map((item) => (
            <li class="flex gap-2 items-start">
              <span class="text-green-500/60 shrink-0 mt-0.5 font-mono">+</span>
              <span class="leading-relaxed">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="p-7 rounded-xl border border-red-500/30 bg-red-500/[0.04]">
        <h3 class="text-lg font-bold mb-5 flex items-center gap-2 text-red-600 dark:text-red-400">
          <X size={20} /> Lo que NO queremos
        </h3>
        <p class="text-xs text-fg-subtle mb-4 italic">
          Esto NO suma, hasta puede restar si parece que llenaste por llenar:
        </p>
        <ul class="space-y-2.5 text-sm">
          {noQueremos.map((item) => (
            <li class="flex gap-2 items-start">
              <span class="text-red-500/60 shrink-0 mt-0.5 font-mono">x</span>
              <span class="leading-relaxed">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
