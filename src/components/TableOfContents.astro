---
import PixelSprite from './PixelSprite.astro';

interface Section {
  id: string;
  label: string;
  hint: string;
  sprite: 'coin' | 'controller' | 'heart' | 'sword' | 'shield' | 'mushroom' | 'star' | 'cartridge' | 'skull' | 'key' | 'cup';
  spriteColor?: string;
  badge?: string; // Letra del escenario si aplica (A/B/C/D/+)
}

interface Group {
  title: string;
  color: string;
  sections: Section[];
}

const groups: Group[] = [
  {
    title: '> ANTES DEL RETO',
    color: '#E75E1E', // naranja brand
    sections: [
      { id: 'tldr',           label: '01. TL;DR',          hint: 'Resumen rápido',           sprite: 'coin' },
      { id: 'rol',            label: '02. El rol',         hint: 'A qué aplicas',            sprite: 'sword' },
      { id: 'espiritu',       label: '03. El espíritu',    hint: 'Cómo pensamos esto',       sprite: 'heart',     spriteColor: 'var(--arcade-red-bright)' },
      { id: 'estructura',     label: '04. La estructura',  hint: '4 partes + 2 opcionales',  sprite: 'cartridge' },
      { id: 'lo-que-recibis', label: '05. Qué recibes',    hint: 'Datos + repo + acceso',    sprite: 'key' },
    ],
  },
  {
    title: '> EL RETO',
    color: '#03A3F8', // azul
    sections: [
      { id: 'caso-negocio',   label: '06. Caso de negocio',     hint: 'Conceptual · 30 min · 25%',          sprite: 'star',       spriteColor: 'var(--arcade-yellow-bright)', badge: 'A' },
      { id: 'reto',           label: '07. Boss Fight (Build)',  hint: '1 de 4 escenarios · 90 min · 35%',   sprite: 'mushroom',   spriteColor: 'var(--arcade-red-bright)',    badge: 'B' },
      { id: 'apendice',       label: '08. Entregable',          hint: 'AI Audit Log + Video · 10%',         sprite: 'cup',        spriteColor: 'var(--arcade-yellow-bright)', badge: '+' },
      { id: 'sesion-en-vivo', label: '09. Sustentación',        hint: 'En vivo · 60 min · 30%',             sprite: 'skull',      spriteColor: 'var(--arcade-red-bright)',    badge: 'C' },
      { id: 'wildcard',       label: '10. Wildcard',            hint: 'Opcional · +5% XP',                  sprite: 'shield',     spriteColor: 'var(--arcade-yellow-bright)', badge: 'D' },
    ],
  },
  {
    title: '> CIERRE',
    color: '#149E71', // verde
    sections: [
      { id: 'evaluacion',     label: '11. Cómo te evaluamos',   hint: 'Rúbrica + criterios',  sprite: 'controller' },
      { id: 'arrancar',       label: '12. Cómo arrancar',       hint: 'Setup en 10 min',      sprite: 'cartridge' },
      { id: 'faq',            label: '13. FAQ',                 hint: 'Preguntas frecuentes', sprite: 'coin' },
    ],
  },
];
---

<nav id="toc" aria-label="Tabla de contenidos" class="py-14 md:py-16 px-6 md:px-8 bg-surface-alt border-y-2 border-fg">
  <div class="max-w-5xl mx-auto">
    <div class="flex items-baseline gap-3 mb-3 flex-wrap">
      <p class="font-pixel text-[10px] uppercase tracking-widest text-brand-primary-text">{'> '} MAPA_DEL_RETO</p>
      <span class="font-pixel text-[9px] text-fg-subtle">presiona <kbd class="px-1.5 py-0.5 border border-fg-subtle font-mono">/</kbd> o <kbd class="px-1.5 py-0.5 border border-fg-subtle font-mono">⌘K</kbd> para búsqueda</span>
    </div>
    <h2 class="text-2xl md:text-4xl font-extrabold mb-2 leading-tight">Tabla de contenidos</h2>
    <p class="text-sm text-fg-muted mb-10 font-mono">
      13 secciones agrupadas · clic en cualquiera para saltar
    </p>

    <div class="space-y-8">
      {groups.map((g) => (
        <div>
          <p class="font-pixel text-[10px] uppercase tracking-widest mb-4 pb-2 border-b-2" style={`color: ${g.color}; border-color: ${g.color};`}>
            {g.title}
          </p>
          <ol class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 list-none">
            {g.sections.map((s) => (
              <li>
                <a
                  href={`#${s.id}`}
                  data-track={`toc_${s.id}`}
                  class="group flex items-center gap-3 p-3 bg-surface border-pixel shadow-pixel-sm hover:translate-x-[-2px] hover:translate-y-[-2px] hover:shadow-pixel-md transition-all"
                  style={`--track-color: ${g.color};`}
                >
                  <span class="shrink-0 grid place-items-center w-9 h-9 pixel-corners border-2 border-fg" style={`background-color: ${g.color}; color: white;`}>
                    {s.badge ? (
                      <span class="font-pixel text-[10px] font-bold">{s.badge}</span>
                    ) : (
                      <PixelSprite type={s.sprite} size={20} class="text-white" />
                    )}
                  </span>
                  <span class="flex-1 min-w-0">
                    <span class="block font-semibold text-sm leading-tight group-hover:text-brand-primary-text transition-colors">{s.label}</span>
                    <span class="block text-[11px] text-fg-subtle font-mono">{s.hint}</span>
                  </span>
                  <span aria-hidden="true" class="text-fg-subtle group-hover:text-brand-primary-text font-mono shrink-0">→</span>
                </a>
              </li>
            ))}
          </ol>
        </div>
      ))}
    </div>
  </div>
</nav>
