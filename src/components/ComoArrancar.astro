---
import { Terminal, GitBranch, FileText, FileCheck, Send, ShieldCheck } from 'lucide-react';

const REPO_URL = 'https://github.com/grrek/loggro-ai-challenge';
const REPO_BLOB = `${REPO_URL}/blob/main`;
const REPO_TREE = `${REPO_URL}/tree/main`;

const pasos = [
  {
    Icon: Terminal,
    code: '01',
    title: 'Asegúrate de tener Claude Code instalado',
    desc: 'O tu equivalente: Cursor, Windsurf, Codex. Si no:',
    code_block: 'npm install -g @anthropic-ai/claude-code',
    link: null,
  },
  {
    Icon: GitBranch,
    code: '02',
    title: 'Clona el template y crea tu repo',
    desc: 'Usa el repo template grrek/loggro-ai-challenge. Marca el tuyo como público (más fácil para que te evaluemos sin permisos). Nómbralo loggro-{track}-{tu-apellido}:',
    code_block: 'gh repo create loggro-{track}-{tu-apellido} \\\n  --template grrek/loggro-ai-challenge \\\n  --public --clone\n# ej. gh repo create loggro-intel-rodriguez ...',
    link: { label: 'Ver repo template', url: REPO_URL },
  },
  {
    Icon: FileText,
    code: '03',
    title: 'Inicia con tu CLAUDE.md propio',
    desc: 'Primer commit "init". El skeleton viene en el template, lo vas llenando a medida que construyes.',
    link: { label: 'Ver CLAUDE.md skeleton', url: `${REPO_BLOB}/CLAUDE.md` },
  },
  {
    Icon: FileCheck,
    code: '04',
    title: 'Lee y firma los 2 documentos legales',
    desc: 'Consentimiento Habeas Data (Ley 1581/2012) y propiedad intelectual. Vienen en /legal/ del template. Suficiente con escribir tu nombre completo + fecha al final de cada uno y commitearlos. Detalles en cada archivo.',
    link: { label: 'Ver carpeta legal/', url: `${REPO_TREE}/legal` },
  },
  {
    Icon: Send,
    code: '05',
    title: 'Mándanos el link de tu repo + tu escenario',
    desc: 'Confirmás que recibiste todo y declaras qué escenario elegiste. Esto NO arranca el cronómetro de 2h: el cronómetro lo arrancás vos (primera entrada del Audit Log) cuando te sentés a hacer Parte A + Boss Fight. El plazo de 48h sí está corriendo desde que te enviamos las instrucciones.',
    code_block: 'mailto: garistizabal@loggro.com',
    link: null,
  },
];
---

<section id="arrancar" class="py-20 md:py-28 px-6 md:px-8 bg-surface-alt">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-baseline gap-3 mb-3">
      <p class="font-pixel text-[10px] uppercase tracking-widest text-brand-primary-text">{'> '} PARTE 0 · SETUP</p>
      <span class="text-xs font-mono text-fg-subtle">~10 min · dentro del plazo, antes del cronómetro</span>
    </div>
    <h2 class="text-3xl md:text-5xl font-bold mb-4 tracking-tight">Cómo arrancar</h2>
    <p class="text-lg text-fg-muted mb-12 max-w-2xl">
      Los primeros 10 minutos: setup del repo + legales. Esto NO consume tu cronómetro de 2h. El plazo de 48h sí está corriendo desde que te enviamos estas instrucciones.
    </p>

    <ol class="space-y-4">
      {pasos.map(({ Icon, code, title, desc, code_block, link }) => (
        <li class="flex gap-5 p-6 rounded-xl border border-line bg-surface">
          <div class="shrink-0 flex flex-col items-center">
            <span class="font-pixel text-sm text-brand-primary-text mb-2">{code}</span>
            <div class="w-10 h-10 grid place-items-center rounded-lg bg-brand-primary/10 text-brand-primary-text">
              <Icon size={18} />
            </div>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="text-base font-bold mb-1.5">{title}</h3>
            <p class="text-sm text-fg-muted leading-relaxed mb-2">{desc}</p>
            {code_block && (
              <pre class="text-xs font-mono bg-surface-alt rounded-md p-3 overflow-x-auto border border-line whitespace-pre">{code_block}</pre>
            )}
            {link && (
              <a
                href={link.url}
                target="_blank"
                rel="noopener"
                class="mt-2 text-xs font-mono text-brand-primary-text hover:underline inline-flex items-center gap-1"
              >
                <span aria-hidden="true">↗</span> {link.label}
              </a>
            )}
          </div>
        </li>
      ))}
    </ol>

    <!-- Disclaimer propiedad intelectual -->
    <div class="mt-10 p-6 bg-surface border-pixel shadow-pixel-md">
      <div class="flex items-start gap-3 mb-3">
        <ShieldCheck size={20} class="text-brand-primary-text shrink-0 mt-0.5" />
        <p class="font-pixel text-[10px] uppercase tracking-widest text-brand-primary-text">
          {'> '} PROPIEDAD INTELECTUAL
        </p>
      </div>
      <p class="text-sm md:text-base text-fg-muted leading-relaxed">
        Mantienes la propiedad de lo que construyes. Si no te contratamos, no usamos comercialmente tu entrega. Si te contratamos, lo que hiciste se vuelve base de tu onboarding y puedes seguir mejorándolo dentro de Loggro. Si decidimos no contratarte pero queremos licenciar algo específico, te buscamos para una conversación separada con compensación.
      </p>
    </div>

    <div class="mt-10 flex flex-wrap gap-4 justify-center items-center">
      <a
        href="https://github.com/grrek/loggro-ai-challenge"
        target="_blank"
        rel="noopener"
        data-track="repo_template"
        class="inline-flex items-center gap-2 px-7 py-4 bg-brand-primary text-black rounded-md font-bold text-lg hover:opacity-90 transition-all glow-primary glow-primary-hover"
      >
        Ir al repo template
        <span aria-hidden="true">{'->'}</span>
      </a>
      <a
        href="#aceptar"
        data-track="arrancar_to_footer"
        class="inline-flex items-center gap-2 px-6 py-4 border-2 border-fg bg-surface-alt font-pixel text-[10px] uppercase tracking-widest btn-pixel"
      >
        <span aria-hidden="true" class="font-mono">↓</span>
        Mandar el correo y arrancar
      </a>
    </div>
  </div>
</section>
