---
import { Terminal, GitBranch, FileText, FileCheck, Send, ShieldCheck } from 'lucide-react';

const pasos = [
  {
    Icon: Terminal,
    code: '01',
    title: 'Asegúrate de tener Claude Code instalado',
    desc: 'O tu equivalente: Cursor, Windsurf, Codex. Si no:',
    code_block: 'npm install -g @anthropic-ai/claude-code',
  },
  {
    Icon: GitBranch,
    code: '02',
    title: 'Clona el template y crea tu repo',
    desc: 'Marca el repo como público. Nómbralo así:',
    code_block: 'loggro-{track}-{tu-apellido}\n# ej. loggro-intel-rodriguez',
  },
  {
    Icon: FileText,
    code: '03',
    title: 'Inicia con tu CLAUDE.md propio',
    desc: 'Primer commit "init". El skeleton viene en el template, lo vas llenando a medida que construyes.',
  },
  {
    Icon: FileCheck,
    code: '04',
    title: 'Lee y firma los 2 documentos legales',
    desc: 'Consentimiento Habeas Data (Ley 1581/2012) y propiedad intelectual. Los firmas digital y los guardas en /legal/ de tu repo.',
  },
  {
    Icon: Send,
    code: '05',
    title: 'Mándanos el link de tu repo',
    desc: 'Confirmando que arrancas y qué track elegiste. El reloj de 48 horas empieza desde ese correo.',
    code_block: 'mailto: garistizabal@loggro.com',
  },
];
---

<section id="arrancar" class="py-20 md:py-28 px-6 md:px-8 bg-surface-alt">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-baseline gap-3 mb-3">
      <p class="font-pixel text-[10px] uppercase tracking-widest text-brand-primary-text">{'> '} PARTE 0 · PREREQUISITOS</p>
      <span class="text-xs font-mono text-fg-subtle">15 min · no cuenta en las 48h</span>
    </div>
    <h2 class="text-3xl md:text-5xl font-bold mb-4 tracking-tight">Cómo arrancar</h2>
    <p class="text-lg text-fg-muted mb-12 max-w-2xl">
      Haz estos 5 pasos antes del cronómetro. 15 minutos. Después arranca el reloj.
    </p>

    <ol class="space-y-4">
      {pasos.map(({ Icon, code, title, desc, code_block }) => (
        <li class="flex gap-5 p-6 rounded-xl border border-line bg-surface">
          <div class="shrink-0 flex flex-col items-center">
            <span class="font-pixel text-sm text-brand-primary-text mb-2">{code}</span>
            <div class="w-10 h-10 grid place-items-center rounded-lg bg-brand-primary/10 text-brand-primary-text">
              <Icon size={18} />
            </div>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="text-base font-bold mb-1.5">{title}</h3>
            <p class="text-sm text-fg-muted leading-relaxed mb-2">{desc}</p>
            {code_block && (
              <pre class="text-xs font-mono bg-surface-alt rounded-md p-3 overflow-x-auto border border-line whitespace-pre">{code_block}</pre>
            )}
          </div>
        </li>
      ))}
    </ol>

    <!-- Disclaimer propiedad intelectual -->
    <div class="mt-10 p-6 bg-surface border-pixel shadow-pixel-md">
      <div class="flex items-start gap-3 mb-3">
        <ShieldCheck size={20} class="text-brand-primary-text shrink-0 mt-0.5" />
        <p class="font-pixel text-[10px] uppercase tracking-widest text-brand-primary-text">
          {'> '} PROPIEDAD INTELECTUAL
        </p>
      </div>
      <p class="text-sm md:text-base text-fg-muted leading-relaxed">
        Mantienes la propiedad de lo que construyes. Si no te contratamos, no usamos comercialmente tu entrega. Si te contratamos, lo que hiciste se vuelve base de tu onboarding y puedes seguir mejorándolo dentro de Loggro. Si decidimos no contratarte pero queremos licenciar algo específico, te buscamos para una conversación separada con compensación.
      </p>
    </div>

    <div class="mt-10 text-center">
      <a
        href="https://github.com/grrek/loggro-ai-challenge"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-7 py-4 bg-brand-primary text-black rounded-md font-bold text-lg hover:opacity-90 transition-all glow-primary glow-primary-hover"
      >
        Ir al repo template
        <span aria-hidden="true">{'->'}</span>
      </a>
    </div>
  </div>
</section>
