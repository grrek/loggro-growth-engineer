      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3 max-w-3xl mx-auto">
        {productos.map((p) => (
          <div
            class="p-4 pixel-corners border-2 border-fg shadow-pixel-sm flex flex-col items-center gap-2 hover:translate-y-[-2px] transition-transform"
