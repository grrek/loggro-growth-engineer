---
const partes = [
  {
    code: '0',
    name: 'Prerequisitos',
    desc: 'Setup: clonar template, firmar consentimiento, mandar link a tu repo',
    tiempo: '10 min',
    peso: '0%',
    async: true,
  },
  {
    code: 'A',
    name: 'Caso de negocio',
    desc: '3 preguntas sobre un snapshot real del funnel de Loggro',
    tiempo: '30 min',
    peso: '25%',
    async: true,
  },
  {
    code: 'B',
    name: 'Boss Fight (Build)',
    desc: 'Eliges 1 de 4 escenarios y construyes hasta donde alcancés',
    tiempo: '90 min',
    peso: '35%',
    async: true,
    destacado: true,
  },
  {
    code: 'Entregable',
    name: 'AI Audit Log + Video',
    desc: 'Bitácora obligatoria + video corto explicando 3 decisiones clave. Sin esto, no se evalúa',
    tiempo: 'dentro del plazo',
    peso: '10%',
    async: true,
  },
  {
    code: 'C',
    name: 'Sustentación',
    desc: 'Presentás, respondemos preguntas, revisamos tu Audit Log juntos. Te lucís, no te defendés',
    tiempo: '60 min',
    peso: '30%',
    async: false,
    destacado: true,
  },
  {
    code: 'D',
    name: 'Wildcard (opcional)',
    desc: 'Sorprendenos: un artefacto extra a tu criterio',
    tiempo: 'libre',
    peso: '+5%',
    async: true,
  },
];

import PixelSprite from './PixelSprite.astro';
---

<section id="estructura" class="py-20 md:py-28 px-6 md:px-8">
  <div class="max-w-5xl mx-auto">
    <div class="flex items-center gap-3 mb-3">
      <PixelSprite type="cartridge" size={26} class="text-brand-primary-text" animated />
      <PixelSprite type="controller" size={28} animated />
    </div>
    <p class="font-pixel text-[10px] uppercase tracking-widest text-brand-primary-text mb-3">
      {'> '} 04 · DE UN VISTAZO
    </p>
    <h2 class="text-3xl md:text-5xl font-bold mb-4 tracking-tight">
      <span class="text-fg-subtle font-mono text-2xl md:text-3xl mr-2">04.</span>La estructura
    </h2>
    <p class="text-lg text-fg-muted mb-12 max-w-2xl">
      Plazo total: 48 horas para entregar. Cronómetro del ejercicio (Parte A + Boss Fight): ~2 horas. Sustentación de 60 min se agenda después de tu entrega.
    </p>

    <div class="overflow-x-auto rounded-xl border border-line">
      <table class="w-full text-sm">
        <thead class="bg-surface-alt border-b border-line">
          <tr>
            <th class="text-left p-4 font-semibold w-20">Parte</th>
            <th class="text-left p-4 font-semibold">Qué es</th>
            <th class="text-left p-4 font-semibold w-32 hidden md:table-cell">Tiempo</th>
            <th class="text-left p-4 font-semibold w-20">Peso</th>
            <th class="text-left p-4 font-semibold w-24 hidden md:table-cell">Modalidad</th>
          </tr>
        </thead>
        <tbody>
          {partes.map((p) => (
            <tr class={`border-b border-line last:border-0 ${p.destacado ? 'bg-brand-primary/[0.03]' : ''}`}>
              <td class="p-4">
                <span class={`font-pixel text-xs px-2 py-1 pixel-corners inline-block ${p.destacado ? 'bg-brand-primary text-black' : 'bg-fg text-surface'}`}>
                  {p.code}
                </span>
              </td>
              <td class="p-4">
                <p class="font-semibold mb-1">{p.name}</p>
                <p class="text-fg-muted text-xs leading-relaxed">{p.desc}</p>
              </td>
              <td class="p-4 text-fg-muted font-mono text-xs hidden md:table-cell">{p.tiempo}</td>
              <td class="p-4">
                <span class={`font-mono text-sm font-semibold ${p.destacado ? 'text-brand-primary-text' : 'text-fg'}`}>
                  {p.peso}
                </span>
              </td>
              <td class="p-4 text-fg-muted text-xs hidden md:table-cell">
                {p.async ? (
                  <span class="font-mono">a tu ritmo</span>
                ) : (
                  <span class="font-mono text-brand-primary-text">en vivo</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p class="text-sm text-fg-subtle font-mono mt-4">
      {'> '} El plazo de 48h inicia cuando te enviamos estas instrucciones por correo. El ejercicio está dimensionado para ~2 horas pero tomate lo que necesites dentro del plazo.
    </p>
  </div>
</section>
