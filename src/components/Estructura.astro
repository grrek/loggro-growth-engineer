---
const partes = [
  {
    code: '0',
    name: 'Prerequisitos',
    desc: 'Setup: clonar template, firmar consentimiento, mandar link a tu repo',
    tiempo: '15 min',
    peso: '0%',
    async: true,
  },
  {
    code: 'A',
    name: 'Caso de negocio',
    desc: '6 preguntas sobre un snapshot real de funnel y atribución de Loggro',
    tiempo: '60 min',
    peso: '15%',
    async: true,
  },
  {
    code: 'B',
    name: 'Build',
    desc: 'Eliges 1 de 4 tracks y construyes el pipeline',
    tiempo: '3 a 4 horas',
    peso: '30%',
    async: true,
    destacado: true,
  },
  {
    code: 'Apéndice',
    name: 'AI Audit Log + Stack + Video',
    desc: 'Documentas cómo trabajaste con IA. Sin esto no se evalúa nada más',
    tiempo: '45 min',
    peso: '15%',
    async: true,
  },
  {
    code: 'C',
    name: 'Sesión en vivo',
    desc: 'Plan / Build / Review con el equipo evaluador. Defensa de 3 decisiones',
    tiempo: '60 min',
    peso: '35%',
    async: false,
    destacado: true,
  },
  {
    code: 'D',
    name: 'Wildcard (opcional)',
    desc: 'Sorprendenos: un artefacto extra a tu criterio',
    tiempo: 'libre',
    peso: '+5%',
    async: true,
  },
];
---

<section id="estructura" class="py-20 md:py-28 px-6 md:px-8">
  <div class="max-w-5xl mx-auto">
    <p class="font-pixel text-[10px] uppercase tracking-widest text-brand-primary-text mb-3">
      {'> '} VISTA DE PÁJARO
    </p>
    <h2 class="text-3xl md:text-5xl font-bold mb-4 tracking-tight">La estructura</h2>
    <p class="text-lg text-fg-muted mb-12 max-w-2xl">
      Total: 5 a 7 horas de trabajo asincrónico dentro de la ventana de 48h, más 60 minutos de sesión en vivo al cierre.
    </p>

    <div class="overflow-x-auto rounded-xl border border-line">
      <table class="w-full text-sm">
        <thead class="bg-surface-alt border-b border-line">
          <tr>
            <th class="text-left p-4 font-semibold w-20">Parte</th>
            <th class="text-left p-4 font-semibold">Qué es</th>
            <th class="text-left p-4 font-semibold w-28 hidden md:table-cell">Tiempo</th>
            <th class="text-left p-4 font-semibold w-20">Peso</th>
            <th class="text-left p-4 font-semibold w-24 hidden md:table-cell">Modalidad</th>
          </tr>
        </thead>
        <tbody>
          {partes.map((p) => (
            <tr class={`border-b border-line last:border-0 ${p.destacado ? 'bg-brand-primary/[0.03]' : ''}`}>
              <td class="p-4">
                <span class={`font-pixel text-xs px-2 py-1 pixel-corners inline-block ${p.destacado ? 'bg-brand-primary text-black' : 'bg-fg text-surface'}`}>
                  {p.code}
                </span>
              </td>
              <td class="p-4">
                <p class="font-semibold mb-1">{p.name}</p>
                <p class="text-fg-muted text-xs leading-relaxed">{p.desc}</p>
              </td>
              <td class="p-4 text-fg-muted font-mono text-xs hidden md:table-cell">{p.tiempo}</td>
              <td class="p-4">
                <span class={`font-mono text-sm font-semibold ${p.destacado ? 'text-brand-primary-text' : 'text-fg'}`}>
                  {p.peso}
                </span>
              </td>
              <td class="p-4 text-fg-muted text-xs hidden md:table-cell">
                {p.async ? (
                  <span class="font-mono">async</span>
                ) : (
                  <span class="font-mono text-brand-primary-text">en vivo</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p class="text-sm text-fg-subtle font-mono mt-4">
      {'> '} El reloj de 48h inicia cuando te enviamos estas instrucciones por correo. Coordinamos día y hora contigo.
    </p>
  </div>
</section>
