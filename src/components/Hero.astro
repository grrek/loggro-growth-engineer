---
import Terminal from './Terminal';
---

<section class="relative min-h-[92vh] flex items-center justify-center px-6 md:px-8 pt-24 pb-16 overflow-hidden cursor-crosshair">
  <!-- Dot grid manual NES -->
  <div aria-hidden="true" class="absolute inset-0 -z-10 dot-grid opacity-[0.35] dark:opacity-[0.12]"></div>

  <!-- Esquinas pixel art (corner markers manual de cartucho) -->
  <div aria-hidden="true" class="absolute top-20 left-6 md:left-10 select-none">
    <div class="font-pixel text-[8px] text-fg flex flex-col gap-1">
      <span class="text-brand-primary-text">▟▙</span>
      <span class="text-brand-primary-text">▔▔</span>
    </div>
  </div>
  <div aria-hidden="true" class="absolute top-20 right-6 md:right-16 select-none">
    <div class="font-pixel text-[8px] text-fg flex flex-col gap-1 items-end">
      <span class="text-brand-primary-text">▙▟</span>
      <span class="text-brand-primary-text">▔▔</span>
    </div>
  </div>
  <div aria-hidden="true" class="absolute bottom-10 left-6 md:left-10 select-none">
    <div class="font-pixel text-[8px] text-fg flex flex-col gap-1">
      <span class="text-brand-primary-text">▁▁</span>
      <span class="text-brand-primary-text">▜▛</span>
    </div>
  </div>
  <div aria-hidden="true" class="absolute bottom-10 right-6 md:right-16 select-none">
    <div class="font-pixel text-[8px] text-fg flex flex-col gap-1 items-end">
      <span class="text-brand-primary-text">▁▁</span>
      <span class="text-brand-primary-text">▛▜</span>
    </div>
  </div>

  <div class="max-w-6xl w-full grid md:grid-cols-2 gap-12 md:gap-16 items-center relative">
    <div class="animate-fade-in">
      <!-- Insignia tipo PRESS START -->
      <div class="inline-flex items-center gap-2 mb-8 px-3 py-2 border-2 border-fg bg-surface-alt shadow-pixel-sm pixel-corners">
        <span class="w-2 h-2 bg-brand-primary animate-blink"></span>
        <p class="font-pixel text-[9px] uppercase tracking-widest">
          VE_1770 / press start
        </p>
      </div>

      <h1 class="text-2xl md:text-4xl lg:text-5xl mb-8 leading-[1.3]">
        Construí con IA.
        <span class="block text-brand-primary-text text-glow-primary mt-3">Como vivís.</span>
      </h1>
      <p class="font-sans text-lg md:text-xl text-fg-muted mb-10 max-w-xl leading-relaxed">
        48 horas, 4 tracks, tu criterio en primer plano. No buscamos perfección. Buscamos cómo pensás cuando la IA te da algo mediocre disfrazado de bueno.
      </p>

      <div class="flex flex-wrap gap-4 items-center">
        <a
          href="#reto"
          class="group relative inline-flex items-center gap-2 px-7 py-4 bg-brand-primary text-black font-pixel text-xs uppercase tracking-widest border-2 border-fg btn-pixel"
        >
          <span>Aceptar el reto</span>
          <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">{'->'}</span>
        </a>
        <a
          href="#espiritu"
          class="inline-flex items-center px-6 py-4 border-2 border-fg bg-surface-alt font-pixel text-[10px] uppercase tracking-widest btn-pixel"
        >
          Ver el espíritu primero
        </a>
      </div>

      <p class="mt-10 text-xs text-fg-subtle font-mono flex items-center gap-2">
        <span class="font-pixel text-[9px] text-brand-primary-text">TIP</span>
        Pulsa <kbd class="px-1.5 py-0.5 rounded border-2 border-fg bg-surface-alt text-fg font-sans">/</kbd> para abrir el command palette
      </p>
    </div>

    <div class="md:pl-8">
      <Terminal client:idle />
    </div>
  </div>

  <!-- Scroll hint pixel art -->
  <div aria-hidden="true" class="absolute bottom-6 left-1/2 -translate-x-1/2 select-none flex flex-col items-center gap-1">
    <span class="font-pixel text-xs text-brand-primary-text animate-bob">▼</span>
    <span class="font-pixel text-[8px] text-fg-subtle uppercase tracking-widest">scroll</span>
  </div>
</section>
