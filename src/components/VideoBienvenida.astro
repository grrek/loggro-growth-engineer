---
// Video de bienvenida vertical (9:16). Self-hosted desde labs.loggro.com.
// Se puede insertar donde tenga sentido: Hero, TLDR, RoleSection.
const LOOM_URL = import.meta.env.PUBLIC_LOOM_URL ?? '';
const VIDEO_URL = import.meta.env.PUBLIC_VIDEO_URL ?? '/growth-engineer/video/reclutamiento-growth-ai-engineer.mp4';
const VIDEO_POSTER = import.meta.env.PUBLIC_VIDEO_POSTER ?? '';
const isLocalMp4 = !LOOM_URL && VIDEO_URL.endsWith('.mp4');

interface Props {
  showLabel?: boolean;
  showCaption?: boolean;
  maxWidth?: string;
  className?: string;
}

const {
  showLabel = true,
  showCaption = true,
  maxWidth = '320px',
  className = '',
} = Astro.props;
---

<div class={`flex flex-col items-center ${className}`}>
  {showLabel && (
    <p class="font-pixel text-[10px] uppercase tracking-widest text-brand-primary-text mb-4 self-start md:self-auto">
      {'> '} VIDEO_DE_BIENVENIDA
    </p>
  )}

  <div
    class="relative w-full aspect-[9/16] bg-black border-pixel shadow-pixel-lg overflow-hidden"
    style={`max-width: ${maxWidth};`}
  >
    {LOOM_URL ? (
      <iframe
        src={LOOM_URL}
        frameborder="0"
        allowfullscreen
        class="absolute inset-0 w-full h-full"
        title="Video de bienvenida del equipo de Loggro"
      ></iframe>
    ) : isLocalMp4 ? (
      <video
        controls
        preload="metadata"
        playsinline
        poster={VIDEO_POSTER || undefined}
        class="absolute inset-0 w-full h-full object-cover bg-black"
      >
        <source src={VIDEO_URL} type="video/mp4" />
        Tu navegador no soporta video HTML5.
      </video>
    ) : (
      <div class="absolute inset-0 flex flex-col items-center justify-center text-white p-8 text-center">
        <p class="font-pixel text-[10px] uppercase tracking-widest mb-3 text-brand-primary">[LOADING.MP4]</p>
        <p class="text-lg">Video de bienvenida (2 a 3 min)</p>
        <p class="text-sm mt-2 text-white/80">Próximamente</p>
      </div>
    )}
  </div>

  {showCaption && (
    <p class="mt-3 text-[11px] font-mono text-fg-subtle text-center">
      ~1:46 · generado con HeyGen · script humano
    </p>
  )}
</div>
