---
interface InputItem {
  text: string;
  url: string | null;
}
interface Track {
  id: string;
  code: string;
  name: string;
  tagline: string;
  descripcion?: string;
  perfil_si: string;
  tiempo: string;
  sub_agentes: string[];
  inputs: InputItem[];
  outputs?: string[];
  rules?: string[];
  bonus?: string;
  brief_url?: string;
  color: string;
}
interface Props {
  track: Track;
}
const { track } = Astro.props;
const repoUrl = import.meta.env.PUBLIC_REPO_URL ?? 'https://github.com/grrek/loggro-ai-challenge';
---

<details
  class="group border-pixel bg-surface shadow-pixel-md overflow-hidden transition-all hover:translate-x-[-2px] hover:translate-y-[-2px] hover:shadow-pixel-lg"
  style={`--track-color: ${track.color};`}
>
  <summary class="cursor-pointer list-none p-6 md:p-8 flex items-start gap-5 [&::-webkit-details-marker]:hidden">
    <div class="shrink-0 relative">
      <div
        class="w-16 h-16 grid place-items-center font-pixel text-base font-bold text-white pixel-corners border-2 border-fg transition-transform group-hover:rotate-[-2deg]"
        style={`background-color: ${track.color}; box-shadow: 4px 4px 0 0 var(--color-fg);`}
      >
        {track.id.toUpperCase()}
      </div>
    </div>

    <div class="flex-1 min-w-0">
      <p class="text-[10px] font-pixel text-fg-subtle mb-2 tracking-widest uppercase">{track.code}</p>
      <h3 class="text-base md:text-lg mb-2 group-hover:text-brand-primary-text transition-colors leading-snug">
        {track.name}
      </h3>
      <p class="text-fg-muted text-sm md:text-base leading-relaxed font-sans">{track.tagline}</p>
    </div>

    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="3"
      stroke-linecap="square"
      stroke-linejoin="miter"
      class="text-fg shrink-0 mt-2 transition-transform group-open:rotate-180"
      aria-hidden="true"
    >
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </summary>

  <div class="px-6 md:px-8 pb-8 pt-2">
    {track.descripcion && (
      <div class="border-t-[3px] pt-6 mb-8" style={`border-color: ${track.color};`}>
        <p class="text-[10px] font-pixel uppercase tracking-widest text-fg-subtle mb-3">Descripción</p>
        <p class="text-sm md:text-base leading-relaxed font-sans text-fg">{track.descripcion}</p>
      </div>
    )}

    <!-- Resumen rapido: para ti si / tiempo / sub-agentes -->
    <div
      class={`grid md:grid-cols-3 gap-6 mb-8 ${track.descripcion ? '' : 'border-t-[3px] pt-6'}`}
      style={!track.descripcion ? `border-color: ${track.color};` : ''}
    >
      <div>
        <p class="text-[10px] font-pixel uppercase tracking-widest text-fg-subtle mb-2">Para ti si</p>
        <p class="text-sm leading-relaxed font-sans">{track.perfil_si}</p>
      </div>
      <div>
        <p class="text-[10px] font-pixel uppercase tracking-widest text-fg-subtle mb-2">Tiempo</p>
        <p class="text-sm font-sans">{track.tiempo}</p>
      </div>
      <div>
        <p class="text-[10px] font-pixel uppercase tracking-widest text-fg-subtle mb-2">Sub-agentes</p>
        <ul class="text-sm space-y-0.5">
          {track.sub_agentes.map((a) => <li class="font-mono text-xs">{`> ${a}`}</li>)}
        </ul>
      </div>
    </div>

    <!-- Inputs + Outputs en 2 columnas -->
    <div class="grid md:grid-cols-2 gap-6 mb-8">
      <div>
        <p class="text-[10px] font-pixel uppercase tracking-widest text-fg-subtle mb-3">{'> '} INPUTS QUE RECIBES</p>
        <ul class="space-y-1.5 text-sm font-sans">
          {track.inputs.map((i) => (
            <li class="flex gap-2">
              <span class="text-brand-primary-text shrink-0 font-pixel">+</span>
              {i.url ? (
                <a
                  href={i.url}
                  target="_blank"
                  rel="noopener"
                  class="underline decoration-dotted underline-offset-2 hover:opacity-80 transition-opacity"
                  style={`color: ${track.color};`}
                >{i.text} <span aria-hidden="true" class="text-fg-subtle">↗</span></a>
              ) : (
                <span>{i.text}</span>
              )}
            </li>
          ))}
        </ul>
      </div>

      {track.outputs && (
        <div>
          <p class="text-[10px] font-pixel uppercase tracking-widest text-fg-subtle mb-3">{'> '} OUTPUTS ESPERADOS</p>
          <ul class="space-y-1.5 text-sm font-sans">
            {track.outputs.map((o) => (
              <li class="flex gap-2"><span class="font-pixel shrink-0" style={`color: ${track.color};`}>★</span> <span>{o}</span></li>
            ))}
          </ul>
        </div>
      )}
    </div>

    <!-- Reglas duras -->
    {track.rules && (
      <div class="mb-8 p-5 border-2 border-fg bg-surface-alt pixel-corners">
        <p class="text-[10px] font-pixel uppercase tracking-widest text-brand-primary-text mb-3">{'> '} REGLAS DURAS DEL TRACK</p>
        <ul class="space-y-1.5 text-sm font-sans">
          {track.rules.map((r) => (
            <li class="flex gap-2"><span class="text-fg-subtle shrink-0 font-pixel">!</span> <span>{r}</span></li>
          ))}
        </ul>
      </div>
    )}

    <!-- Bonus si existe -->
    {track.bonus && (
      <div class="mb-8 p-5 border-2 border-fg bg-brand-primary/[0.08] pixel-corners">
        <p class="text-[10px] font-pixel uppercase tracking-widest text-brand-primary-text mb-2">{'> '} BONUS QUE SUMA PUNTOS</p>
        <p class="text-sm leading-relaxed font-sans">{track.bonus}</p>
      </div>
    )}

    <!-- CTAs -->
    <div class="flex flex-wrap gap-3">
      {track.brief_url && (
        <a
          href={track.brief_url}
          target="_blank"
          rel="noopener"
          data-track={`brief_link_${track.id}`}
          class="group/cta inline-flex items-center gap-2 px-5 py-3 bg-brand-primary text-black font-pixel text-[10px] uppercase tracking-widest border-2 border-fg btn-pixel"
        >
          Leer BRIEF.md completo
          <span aria-hidden="true" class="transition-transform group-hover/cta:translate-x-1">↗</span>
        </a>
      )}
      <a
        href={repoUrl}
        target="_blank"
        rel="noopener"
        data-track={`repo_link_${track.id}`}
        class="group/cta inline-flex items-center gap-2 px-5 py-3 bg-fg text-surface font-pixel text-[10px] uppercase tracking-widest border-2 border-fg btn-pixel hover:bg-brand-primary hover:text-black"
      >
        Ir al repo template
        <span aria-hidden="true" class="transition-transform group-hover/cta:translate-x-1">{'->'}</span>
      </a>
    </div>
  </div>
</details>
