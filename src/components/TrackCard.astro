---
interface Track {
  id: string;
  code: string;
  name: string;
  tagline: string;
  perfil_si: string;
  tiempo: string;
  sub_agentes: string[];
  inputs: string[];
  color: string;
}
interface Props {
  track: Track;
}
const { track } = Astro.props;
const repoUrl = import.meta.env.PUBLIC_REPO_URL ?? 'https://github.com/grrek/loggro-ai-challenge';
---

<details
  class="group border border-line rounded-xl bg-surface overflow-hidden transition-all hover:border-brand-primary/40 hover:shadow-lg"
  style={`--track-color: ${track.color};`}
>
  <summary class="cursor-pointer list-none p-6 md:p-8 flex items-start gap-5 [&::-webkit-details-marker]:hidden">
    <!-- Pixel art badge -->
    <div class="shrink-0 relative">
      <div
        class="w-16 h-16 grid place-items-center font-pixel text-xs font-bold text-white pixel-corners transition-transform group-hover:scale-105 group-hover:rotate-[-2deg]"
        style={`background-color: ${track.color}; box-shadow: 4px 4px 0 0 var(--color-fg);`}
      >
        {track.id.toUpperCase()}
      </div>
    </div>

    <div class="flex-1 min-w-0">
      <p class="text-[10px] font-pixel text-fg-subtle mb-1.5 tracking-widest uppercase">{track.code}</p>
      <h3 class="text-xl md:text-2xl font-bold mb-2 group-hover:text-brand-primary transition-colors">
        {track.name}
      </h3>
      <p class="text-fg-muted text-sm md:text-base leading-relaxed">{track.tagline}</p>
    </div>

    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="text-fg-subtle shrink-0 mt-2 transition-transform group-open:rotate-180"
      aria-hidden="true"
    >
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </summary>

  <div class="px-6 md:px-8 pb-8 pt-2">
    <div
      class="border-t-2 pt-6 grid md:grid-cols-3 gap-6 mb-6"
      style={`border-color: ${track.color};`}
    >
      <div>
        <p class="text-[10px] font-pixel uppercase tracking-widest text-fg-subtle mb-2">Para vos si</p>
        <p class="text-sm leading-relaxed">{track.perfil_si}</p>
      </div>
      <div>
        <p class="text-[10px] font-pixel uppercase tracking-widest text-fg-subtle mb-2">Tiempo</p>
        <p class="text-sm">{track.tiempo}</p>
      </div>
      <div>
        <p class="text-[10px] font-pixel uppercase tracking-widest text-fg-subtle mb-2">Sub-agentes</p>
        <ul class="text-sm space-y-0.5">
          {track.sub_agentes.map((a) => <li class="font-mono text-xs">{`> ${a}`}</li>)}
        </ul>
      </div>
    </div>

    <div class="mb-6">
      <p class="text-[10px] font-pixel uppercase tracking-widest text-fg-subtle mb-2">Inputs que recibis</p>
      <ul class="grid md:grid-cols-2 gap-1 text-sm">
        {track.inputs.map((i) => <li class="flex gap-2"><span class="text-brand-primary shrink-0">+</span> {i}</li>)}
      </ul>
    </div>

    <a
      href={repoUrl}
      target="_blank"
      rel="noopener"
      class="group/cta inline-flex items-center gap-2 px-5 py-3 bg-fg text-surface rounded-md text-sm font-semibold hover:bg-brand-primary transition-all"
    >
      Elegir este track y arrancar mi reloj
      <span aria-hidden="true" class="transition-transform group-hover/cta:translate-x-1">{'->'}</span>
    </a>
  </div>
</details>
