---
interface Track {
  id: string;
  code: string;
  name: string;
  tagline: string;
  perfil_si: string;
  tiempo: string;
  sub_agentes: string[];
  inputs: string[];
  color: string;
}
interface Props {
  track: Track;
}
const { track } = Astro.props;
const repoUrl = import.meta.env.PUBLIC_REPO_URL ?? 'https://github.com/grrek/loggro-ai-challenge';
---

<details
  class="group border-pixel bg-surface shadow-pixel-md overflow-hidden transition-all hover:translate-x-[-2px] hover:translate-y-[-2px] hover:shadow-pixel-lg"
  style={`--track-color: ${track.color};`}
>
  <summary class="cursor-pointer list-none p-6 md:p-8 flex items-start gap-5 [&::-webkit-details-marker]:hidden">
    <!-- Pixel badge con sombra solida 8-bit -->
    <div class="shrink-0 relative">
      <div
        class="w-16 h-16 grid place-items-center font-pixel text-base font-bold text-white pixel-corners border-2 border-fg transition-transform group-hover:rotate-[-2deg]"
        style={`background-color: ${track.color}; box-shadow: 4px 4px 0 0 var(--color-fg);`}
      >
        {track.id.toUpperCase()}
      </div>
    </div>

    <div class="flex-1 min-w-0">
      <p class="text-[10px] font-pixel text-fg-subtle mb-2 tracking-widest uppercase">{track.code}</p>
      <h3 class="text-base md:text-lg mb-2 group-hover:text-brand-primary-text transition-colors leading-snug">
        {track.name}
      </h3>
      <p class="text-fg-muted text-sm md:text-base leading-relaxed font-sans">{track.tagline}</p>
    </div>

    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="3"
      stroke-linecap="square"
      stroke-linejoin="miter"
      class="text-fg shrink-0 mt-2 transition-transform group-open:rotate-180"
      aria-hidden="true"
    >
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </summary>

  <div class="px-6 md:px-8 pb-8 pt-2">
    <div
      class="border-t-[3px] pt-6 grid md:grid-cols-3 gap-6 mb-6"
      style={`border-color: ${track.color};`}
    >
      <div>
        <p class="text-[10px] font-pixel uppercase tracking-widest text-fg-subtle mb-2">Para ti si</p>
        <p class="text-sm leading-relaxed font-sans">{track.perfil_si}</p>
      </div>
      <div>
        <p class="text-[10px] font-pixel uppercase tracking-widest text-fg-subtle mb-2">Tiempo</p>
        <p class="text-sm font-sans">{track.tiempo}</p>
      </div>
      <div>
        <p class="text-[10px] font-pixel uppercase tracking-widest text-fg-subtle mb-2">Sub-agentes</p>
        <ul class="text-sm space-y-0.5">
          {track.sub_agentes.map((a) => <li class="font-mono text-xs">{`> ${a}`}</li>)}
        </ul>
      </div>
    </div>

    <div class="mb-6">
      <p class="text-[10px] font-pixel uppercase tracking-widest text-fg-subtle mb-2">Inputs que recibes</p>
      <ul class="grid md:grid-cols-2 gap-1 text-sm font-sans">
        {track.inputs.map((i) => <li class="flex gap-2"><span class="text-brand-primary-text shrink-0 font-pixel">+</span> {i}</li>)}
      </ul>
    </div>

    <a
      href={repoUrl}
      target="_blank"
      rel="noopener"
      class="group/cta inline-flex items-center gap-2 px-5 py-3 bg-fg text-surface font-pixel text-[10px] uppercase tracking-widest border-2 border-fg btn-pixel hover:bg-brand-primary hover:text-black"
    >
      Ir al repo de este track
      <span aria-hidden="true" class="transition-transform group-hover/cta:translate-x-1">{'->'}</span>
    </a>
  </div>
</details>
