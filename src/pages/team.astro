---
import Base from '../layouts/Base.astro';
import TrackingListener from '../components/TrackingListener';

const team = [
  { name: 'Gregorio Aristizábal', role: 'Director de Crecimiento y Marketing', pilar: 'Dirección Estratégica' },
  { name: 'Kathy Porras Eslava', role: 'Analista Marketing Digital (Líder)', pilar: 'Performance & Growth' },
  { name: 'Adrian Montoya Calle', role: 'Analista Marketing Digital', pilar: 'Performance & Growth' },
  { name: 'Kissy Marín Galeano', role: 'Analista Marketing Digital (SEO)', pilar: 'Organic Growth' },
  { name: 'Ana María Roldán Ospina', role: 'Comunicadora Digital', pilar: 'Organic Growth' },
  { name: 'Ana Marly Orrego Parra', role: 'Diseñadora UI y Video', pilar: 'Creative' },
  { name: 'Albert Anaya Pitalua', role: 'Diseñador UI/UX', pilar: 'Creative' },
  { name: 'Sergio Rendón G.', role: 'Webmaster', pilar: 'MarkOps' },
  { name: 'Tú, si llegas al rol', role: 'Growth Engineer — Automatización & IA', pilar: 'MarkOps', highlight: true },
];
---

<Base title="El equipo - Loggro VE-1770" description="Conoce al equipo de Marketing y Growth de Loggro al que te unirás si llegas al rol.">
  <main class="max-w-4xl mx-auto px-6 md:px-8 py-24">
    <div class="font-mono text-[11px] text-fg-subtle mb-8 flex justify-between items-center select-none">
      <span class="font-pixel text-[9px] text-brand-primary-text tracking-widest">{'> '}PAGINA_OCULTA / TEAM</span>
      <span class="font-mono text-[10px]">[ESC] volver</span>
    </div>

    <h1 class="text-4xl md:text-6xl font-bold mb-6 tracking-tight">
      A este equipo<br />
      <span class="text-brand-primary-text text-glow-primary">te unes.</span>
    </h1>
    <p class="text-lg text-fg-muted mb-12 leading-relaxed">
      9 personas operando Marketing y Growth de Loggro. Aquí está el equipo al que reportarías, y la silla que va a ocupar quien gane el VE-1770.
    </p>

    <!-- Frame pixel art para la foto -->
    <div class="relative mb-12">
      <div class="absolute -top-2 -left-2 w-6 h-6 border-t-4 border-l-4 border-brand-primary"></div>
      <div class="absolute -top-2 -right-2 w-6 h-6 border-t-4 border-r-4 border-brand-primary"></div>
      <div class="absolute -bottom-2 -left-2 w-6 h-6 border-b-4 border-l-4 border-brand-primary"></div>
      <div class="absolute -bottom-2 -right-2 w-6 h-6 border-b-4 border-r-4 border-brand-primary"></div>

      <div class="rounded-2xl overflow-hidden border border-line bg-surface-alt aspect-[2/1] grid place-items-center relative">
        <img
          src="/growth-engineer/team.jpg"
          alt="Equipo de Marketing y Growth de Loggro en un evento"
          class="w-full h-full object-cover"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
        />
        <div class="hidden w-full h-full flex-col items-center justify-center p-8 text-center text-fg-muted absolute inset-0">
          <p class="font-pixel text-[10px] text-brand-primary-text tracking-widest mb-3">[LOADING.IMG]</p>
          <p class="text-lg">Foto del equipo próximamente.</p>
          <p class="text-sm text-fg-subtle mt-2">Mientras tanto, los nombres y roles abajo.</p>
        </div>
      </div>

      <p class="text-center mt-4 font-mono text-xs text-fg-subtle">
        marketing-growth.jpg
      </p>
    </div>

    <ul class="grid md:grid-cols-2 gap-3">
      {team.map((p, i) => (
        <li class={`p-5 rounded-lg border transition-all ${p.highlight ? 'border-brand-primary bg-brand-primary/[0.06] glow-primary' : 'border-line hover:border-brand-primary/30'}`}>
          <div class="flex items-baseline gap-3 mb-1">
            <span class={`font-pixel text-[9px] ${p.highlight ? 'text-brand-primary-text' : 'text-fg-subtle'} shrink-0`}>{String(i + 1).padStart(2, '0')}</span>
            <p
              class={`font-semibold ${p.highlight ? 'text-brand-primary-text' : ''}`}
              {...(p.highlight ? { 'data-personalize': 'self', 'data-personalize-template': '{name}, si llegas al rol' } : {})}
            >{p.name}</p>
          </div>
          <p class="text-sm text-fg-muted mt-0.5 pl-7">{p.role}</p>
          <p class="text-[10px] text-fg-subtle font-pixel mt-1.5 pl-7 uppercase tracking-widest">{p.pilar}</p>
        </li>
      ))}
    </ul>

    <div class="mt-12 p-6 rounded-xl border border-line bg-surface-alt">
      <p class="text-sm text-fg-muted leading-relaxed">
        <strong class="text-fg">Reportas al Director de Crecimiento.</strong> Trabajas día a día al lado del Performance Analyst que ya está en el equipo y te complementa. Coordinas con Performance Lead (SEM/Paid), SEO, Comunicación y Diseño. El Tech Lead de Loggro te apoya en arquitectura de automatizaciones complejas.
      </p>
    </div>

    <div class="mt-12 text-center">
      <a href="/growth-engineer" class="inline-flex items-center gap-2 px-6 py-3 border border-line rounded-md font-semibold hover:bg-surface-alt transition-colors">
        <span aria-hidden="true">{'<-'}</span>
        Volver al microsite
      </a>
    </div>
  </main>
  <TrackingListener client:idle />
</Base>
