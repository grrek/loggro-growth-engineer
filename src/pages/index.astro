---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import TLDR from '../components/TLDR.astro';
import RoleSection from '../components/RoleSection.astro';
import Estructura from '../components/Estructura.astro';
import CasoNegocio from '../components/CasoNegocio.astro';
import TrackCards from '../components/TrackCards.astro';
import LoQueRecibis from '../components/LoQueRecibis.astro';
import Apendice from '../components/Apendice.astro';
import SesionEnVivo from '../components/SesionEnVivo.astro';
import Wildcard from '../components/Wildcard.astro';
import Espiritu from '../components/Espiritu.astro';
import ComoEvaluamos from '../components/ComoEvaluamos.astro';
import ComoArrancar from '../components/ComoArrancar.astro';
import Referencias from '../components/Referencias.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
import AsciiDivider from '../components/AsciiDivider.astro';
import CommandPalette from '../components/CommandPalette';
import KonamiOverlay from '../components/KonamiOverlay';
---

<Base title="Loggro - Reto VE-1770" description="Reto técnico para el rol de Especialista en Automatización, IA y Growth en Loggro. 48 horas. 4 tracks. Tu criterio en primer plano.">
  <main id="top">
    <Hero />
    <AsciiDivider variant="dots" />
    <TLDR />
    <AsciiDivider variant="angle" />
    <RoleSection />
    <AsciiDivider variant="dashes" />
    <Estructura />
    <AsciiDivider variant="plus" />
    <CasoNegocio />
    <AsciiDivider variant="brackets" />
    <TrackCards />
    <AsciiDivider variant="dashes" />
    <LoQueRecibis />
    <AsciiDivider variant="brackets" />
    <Apendice />
    <AsciiDivider variant="angle" />
    <SesionEnVivo />
    <AsciiDivider variant="plus" />
    <Wildcard />
    <AsciiDivider variant="wave" />
    <Espiritu />
    <AsciiDivider variant="dashes" />
    <ComoEvaluamos />
    <AsciiDivider variant="brackets" />
    <ComoArrancar />
    <AsciiDivider variant="dots" />
    <Referencias />
    <AsciiDivider variant="dots" />
    <FAQ />
  </main>
  <Footer />
  <CommandPalette client:idle />
  <KonamiOverlay client:idle />
</Base>
